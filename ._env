# Required: Device codename
DEVICE="warm"
ROM_NAME="LineageOS"

# Required: git username
GIT_NAME="shyam-vadgama"
# Required: git email
GIT_EMAIL="shyamvadgama76@gmail.com"

# Required: Personal Access Token from GitHub with permissions repo, admin:repo_hook, user
# Better set it as a secret in your GitHub repo settings
# RELEASE_GITHUB_TOKEN=""

# Required: Repository owner/repo to upload and release build files
GITHUB_RELEASE_REPO="shyam-vadgama/warm-LineageOS"

# Required: To upload the build, set this
RELEASE_FILES_PATTERN="*.zip|*.md5sum|*.sha256sum"

# Required: Repos to clone
REPOS_JSON="repos.json"

# Required: Output directory for release files
RELEASE_OUT_DIR="out/target/product/$DEVICE"

# Optional: Clone local manifest right after repo init
POST_SETUP_SOURCE_COMMAND="git clone https://github.com/shyam-vadgama/local_manifest -b lineage-23.2 .repo/local_manifests || (cd .repo/local_manifests && git pull)"

# Required: repo init
SETUP_SOURCE_COMMAND="repo init -u https://github.com/LineageOS/android.git -b lineage-23.2 --git-lfs --depth=1"

# Required: repo sync
SYNC_SOURCE_COMMAND="repo sync -c --force-remove-dirty --optimized-fetch --prune --force-sync -j\$(nproc --all)"

# Required: Build command
BUILD_VANILLA_COMMAND=". build/envsetup.sh && lunch lineage_warm-ap4a-userdebug && mka bacon"

# GApps build command (skip)
BUILD_GAPPS_COMMAND=""

# Optional: If you do not want logs
# LOG_OUTPUT=false

# Optional: if you want updates in telegram
# TG_TOKEN=""
# TG_CHAT=""

# Optional: if you want to remove OTA Package
REMOVE_OTA_PACKAGE=true

# Optional: if you want to upload to sourceforge
SF_UPLOAD=false
